{
  "name": "knocoph",
  "description": "Knocoph is a local MCP server that parses TypeScript and JavaScript codebases into a persistent knowledge graph stored in SQLite.",
  "version": "1.5.0",
  "author": "José Antonio González Rodríguez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jagonzalr/knocoph/issues"
  },
  "homepage": "https://github.com/jagonzalr/knocoph#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jagonzalr/knocoph.git"
  },
  "keywords": [
    "MCP",
    "TypeScript",
    "JavaScript",
    "knowledge graph",
    "code analysis",
    "static analysis",
    "code visualization",
    "developer tools"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "knocoph": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "lint": "eslint --fix .",
    "prettier": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@typescript-eslint/typescript-estree": "8.59.1",
    "better-sqlite3": "12.9.0",
    "chokidar": "5.0.0",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run prettier",
      "npm run lint"
    ]
  }
}
